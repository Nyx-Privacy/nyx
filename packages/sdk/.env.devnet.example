# Phase 3 devnet E2E test config. Copy to .env.devnet and fill in the blanks.
# .env.devnet is gitignored.

# ---- L1 (Solana devnet) RPC ----
# Public fallback: https://api.devnet.solana.com (rate-limited)
# Preferred: a Helius / QuickNode / Triton devnet URL with your API key.
L1_RPC_URL=https://api.devnet.solana.com

# ---- MagicBlock PER (TEE) ----
# Public hosted endpoint; no API key needed.
PER_BASE_URL=https://tee.magicblock.app

# ---- Program ids ----
# These are baked into the compiled .so files at target/deploy/.
# Do not change unless you rebuild with new program keypairs.
VAULT_PROGRAM_ID=AB8ZJYgG6jNzfzQAgHHC9DNuQF6tB48UYqCWuseZ59XW
MATCHING_ENGINE_PROGRAM_ID=G8MHBmzhfvRnhejot7XfeSFm3NC96uqm7VNduutM1J2K

# ---- MagicBlock ER infrastructure (reference; do not change) ----
PERMISSION_PROGRAM_ID=ACLseoPoyC3cBqoUtkbjZ4aDrkurZW86v19pXz2XQnp1
ER_VALIDATOR=FnE6VJT5QNZdedZPnCoLsARgBwoE6DeJNjBs2H1gySXA

# ---- Test fixture keypair paths (generated by scripts/setup-devnet.sh) ----
ADMIN_KEYPAIR=.devnet/keypairs/admin.json
TEE_AUTHORITY_KEYPAIR=.devnet/keypairs/tee_authority.json
ROOT_KEY_KEYPAIR=.devnet/keypairs/root_key.json
TRADER_KEYPAIR=.devnet/keypairs/trader.json

# ---- Test gate ----
# Only runs when RUN_PER_TESTS=1 is set. Leave unset for normal CI.
# RUN_PER_TESTS=1
